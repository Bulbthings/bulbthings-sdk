{
    "name": "bulbthings-javascript-sdk",
    "version": "0.4.3",
    "description": "BulbThings API wrapper",
    "main": "dist/index.js",
    "typings": "dist/index.d.ts",
    "scripts": {
        "prepare": "npm run build",
        "build": "tsc --declaration && copyfiles -u 1 src/*.js dist/",
        "test": "mocha -r ts-node/register --exit --recursive \"tests/**/*.ts\""
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged --ignore-path=docs"
        }
    },
    "prettier": {
        "tabWidth": 4,
        "singleQuote": true
    },
    "dependencies": {
        "cross-fetch": "^3.0.2",
        "eventsource": "^1.0.7",
        "jsonapi-typescript": "^0.1.0",
        "qs": "^6.7.0",
        "reflect-metadata": "^0.1.13"
    },
    "devDependencies": {
        "@types/chai": "^4.1.4",
        "@types/eventsource": "^1.1.0",
        "@types/mocha": "^5.2.5",
        "@types/qs": "^6.5.2",
        "@types/reflect-metadata": "^0.1.0",
        "chai": "^4.1.2",
        "copyfiles": "^2.1.0",
        "dotenv": "^7.0.0",
        "husky": "^2.3.0",
        "mocha": "^6.1.3",
        "prettier": "^1.17.1",
        "pretty-quick": "^1.10.0",
        "ts-node": "^8.1.0",
        "typescript": "^3.0.3"
    }
}
