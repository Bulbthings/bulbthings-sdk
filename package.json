{
    "name": "bulbthings-sdk",
    "version": "0.35.0",
    "description": "Isomorphic JavaScript/TypeScript SDK for the Bulbthings API",
    "main": "dist/index.js",
    "typings": "dist/index.d.ts",
    "scripts": {
        "prepare": "npm run build",
        "build": "tsc --declaration && copyfiles -u 1 src/*.js dist/",
        "test": "mocha -r ts-node/register --exit --recursive \"tests/**/*.ts\""
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged --ignore-path=docs"
        }
    },
    "prettier": {
        "tabWidth": 4,
        "singleQuote": true
    },
    "dependencies": {
        "@types/json-schema": "7.0.15",
        "async-mutex": "0.4.0",
        "cross-eventsource": "https://github.com/Bulbthings/cross-eventsource.git#0.2.0",
        "cross-fetch": "3.1.8",
        "form-data": "3.0.1",
        "isomorphic-form-data": "2.0.0",
        "jsonapi-typescript": "0.1.3",
        "qs": "6.11.2",
        "reflect-metadata": "0.1.14",
        "uuid": "9.0.1"
    },
    "devDependencies": {
        "@types/chai": "4.3.11",
        "@types/isomorphic-form-data": "2.0.4",
        "@types/mocha": "8.2.3",
        "@types/node": "14.18.63",
        "@types/pluralize": "0.0.29",
        "@types/qs": "6.9.11",
        "@types/reflect-metadata": "0.1.0",
        "chai": "4.4.1",
        "copyfiles": "2.4.1",
        "dotenv": "8.6.0",
        "husky": "4.3.8",
        "mocha": "8.4.0",
        "mockdate": "3.0.5",
        "nock": "13.5.0",
        "prettier": "2.8.8",
        "pretty-quick": "2.0.2",
        "ts-node": "8.10.2",
        "typescript": "3.9.10"
    }
}
