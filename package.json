{
    "name": "bulbthings-sdk",
    "version": "0.16.1",
    "description": "Isomorphic JavaScript/TypeScript SDK for the Bulbthings API",
    "main": "dist/index.js",
    "typings": "dist/index.d.ts",
    "scripts": {
        "prepare": "npm run build",
        "build": "tsc --declaration && copyfiles -u 1 src/*.js dist/",
        "test": "mocha -r ts-node/register --exit --recursive \"tests/**/*.ts\""
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged --ignore-path=docs"
        }
    },
    "prettier": {
        "tabWidth": 4,
        "singleQuote": true
    },
    "dependencies": {
        "@types/json-schema": "^7.0.5",
        "async-mutex": "^0.2.4",
        "cross-eventsource": "https://github.com/Bulbthings/cross-eventsource.git#0.1.0",
        "cross-fetch": "^3.0.5",
        "form-data": "^3.0.0",
        "isomorphic-form-data": "^2.0.0",
        "jsonapi-typescript": "^0.1.3",
        "pluralize": "^8.0.0",
        "qs": "^6.9.4",
        "reflect-metadata": "^0.1.13"
    },
    "devDependencies": {
        "@types/chai": "^4.2.11",
        "@types/isomorphic-form-data": "^2.0.0",
        "@types/mocha": "^8.0.0",
        "@types/node": "^14.0.24",
        "@types/pluralize": "0.0.29",
        "@types/qs": "^6.9.3",
        "@types/reflect-metadata": "^0.1.0",
        "chai": "^4.2.0",
        "copyfiles": "^2.3.0",
        "dotenv": "^8.2.0",
        "husky": "^4.2.5",
        "mocha": "^8.0.1",
        "mockdate": "^3.0.2",
        "nock": "^13.0.2",
        "prettier": "^2.0.5",
        "pretty-quick": "^2.0.1",
        "ts-node": "^8.10.2",
        "typescript": "^3.9.7"
    }
}
