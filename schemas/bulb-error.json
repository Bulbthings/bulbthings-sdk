{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "failure",
    "definitions": {
        "error": {
            "allOf": [
                { "$ref": "http://jsonapi.org/schema#/definitions/error" },
                {
                    "properties": {
                        "code": {
                            "type": "string",
                            "enum": ["api", "sdk", "connection"]
                        }
                    },
                    "required": ["code", "title"]
                }
            ]
        }
    },
    "allOf": [
        { "$ref": "http://jsonapi.org/schema#/definitions/failure" },
        {
            "properties": {
                "errors": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/error"
                    },
                    "uniqueItems": true
                }
            }
        }
    ]
}
